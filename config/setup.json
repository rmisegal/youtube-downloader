{
  "version": "1.06",
  "paths": {
    "output_dir": "./downloads"
  },
  "pipeline": {
    "scene_target": 24,
    "sync_target": "video_art",
    "mode": "bar",
    "output_dir": "./movies"
  },
  "llm": {
    "vendor": "claude",
    "auth": "cli",
    "api": { "model": "claude-opus-4-8" },
    "providers": {
      "claude": {
        "executable": "claude",
        "args": ["-p"],
        "strip_env_keys": ["ANTHROPIC_API_KEY", "CLAUDECODE", "ANTHROPIC_BASE_URL", "ANTHROPIC_AUTH_TOKEN", "API_TIMEOUT_MS"]
      },
      "gemini": {
        "executable": "gemini",
        "args": [],
        "strip_env_keys": ["GEMINI_API_KEY", "GOOGLE_API_KEY"]
      }
    }
  },
  "analysis": {
    "default_fps": 30,
    "default_levels": ["beat", "bar", "phrase", "section"],
    "meter": 4,
    "phrase_bars": 8,
    "sample_rate": 22050,
    "downbeat_backend": "auto",
    "use_gpu": "auto",
    "default_target": "video_art"
  },
  "playback": {
    "default_mode": "option2",
    "default_selection": "random",
    "crossfade_duration_seconds": 3,
    "source_mix_time_seconds": null,
    "target_start_time_seconds": 0,
    "supported_video_formats": [".mp4", ".mkv", ".mov", ".avi"]
  },
  "network": {
    "js_runtime": "auto"
  },
  "defaults": {
    "resolution": null,
    "sub_lang": "en",
    "modes": ["video"]
  },
  "audio": {
    "codec": "mp3",
    "quality": "192"
  },
  "subtitles": {
    "format": "srt",
    "include_auto": true
  },
  "ffmpeg": {
    "location": "auto"
  },
  "sample": {
    "play_seconds": 10,
    "mid_band_low": 0.25,
    "mid_band_high": 0.75,
    "loop": true
  },
  "render": {
    "width": 1280,
    "height": 720,
    "fps": 30,
    "video_preset": "ultrafast",
    "video_codec": "libx264",
    "audio_codec": "aac",
    "container": "mp4"
  },
  "logging": {
    "dir": "logs",
    "app_file": "ytdl.log",
    "subprocess_file": "ffmpeg.log",
    "max_bytes": 1048576,
    "console_level": "ERROR"
  }
}
