{
  "version": "1.05",
  "paths": {
    "output_dir": "./downloads"
  },
  "analysis": {
    "default_fps": 30,
    "default_levels": ["beat", "bar", "phrase", "section"],
    "meter": 4,
    "phrase_bars": 8,
    "sample_rate": 22050,
    "downbeat_backend": "auto",
    "use_gpu": "auto",
    "fill_on_phrase_end": true,
    "section_rules": {
      "Intro": "phrase",
      "Verse": "bar",
      "Build-up": "beat",
      "Chorus": "beat",
      "Outro": "phrase"
    },
    "tier_transitions": {
      "beat": "pulse",
      "bar": "fade",
      "phrase": "zoomout",
      "section": "panright"
    },
    "section_transitions": {
      "Intro": "zoomout",
      "Verse": "fade",
      "Build-up": "shake",
      "Chorus": "pulse",
      "Outro": "zoomout"
    }
  },
  "playback": {
    "default_mode": "option2",
    "default_selection": "random",
    "crossfade_duration_seconds": 3,
    "source_mix_time_seconds": null,
    "target_start_time_seconds": 0,
    "supported_video_formats": [".mp4", ".mkv", ".mov", ".avi"]
  },
  "network": {
    "js_runtime": "auto"
  },
  "defaults": {
    "resolution": null,
    "sub_lang": "en",
    "modes": ["video"]
  },
  "audio": {
    "codec": "mp3",
    "quality": "192"
  },
  "subtitles": {
    "format": "srt",
    "include_auto": true
  },
  "ffmpeg": {
    "location": "auto"
  },
  "sample": {
    "play_seconds": 10,
    "mid_band_low": 0.25,
    "mid_band_high": 0.75,
    "loop": true
  },
  "render": {
    "width": 1280,
    "height": 720,
    "fps": 30,
    "video_preset": "ultrafast",
    "video_codec": "libx264",
    "audio_codec": "aac",
    "container": "mp4"
  },
  "logging": {
    "dir": "logs",
    "app_file": "ytdl.log",
    "subprocess_file": "ffmpeg.log",
    "max_bytes": 1048576,
    "console_level": "ERROR"
  }
}
