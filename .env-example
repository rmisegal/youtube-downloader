# Optional, user-supplied secrets for YouTube downloads.
# Copy this file to `.env` and fill values as needed. `.env` is git-ignored.
# Public YouTube videos require NO values here.

# Optional HTTP/HTTPS/SOCKS proxy URL passed to yt-dlp (e.g. http://host:port).
YTDL_PROXY=

# Optional path to a Netscape-format cookies.txt for age/region-gated public videos.
YTDL_COOKIES_FILE=

# --- Movie pipeline LLM (PRD-mix-video-pipeline) ---
# The script step defaults to Claude via CLI LOGIN (no key needed). These are ONLY
# used with `--auth api`; under CLI login they are scrubbed from the child env.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
